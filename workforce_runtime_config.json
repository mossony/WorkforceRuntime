{
  "runtime": {
    "store_backend": "mysql",
    "db_path": "workforce_runtime",
    "workspace_root": ".workforce_runtime",
    "task_trace_dir": "",
    "task_trace_include_file_contents": true,
    "task_trace_max_file_bytes": 500000
