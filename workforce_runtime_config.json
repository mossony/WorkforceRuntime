  "openrouter": {
    "chat_completions_url": "https://openrouter.ai/api/v1/chat/completions",
    "api_key_env": "OPENROUTER_API_KEY",
    "timeout_seconds": 90,
    "reasoning_enabled": true,
    "stream": false,
